# TMDB API Configuration
# Get your key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Database Configuration (MySQL)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=password123
DB_NAME=horror_helper_db

# Auth0 API Security
# The 'Audience' is the API Identifier you created in the Auth0 Dashboard
AUTH0_AUDIENCE=https://your-audience.com
# The 'Issuer Base URL' is usually your Auth0 Domain prefixed with https://
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com/
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_backend_client_id

# Auth0 Management API
# Required if your backend needs to update user metadata or roles
AUTH0_MGMT_CLIENT_ID=your_management_client_id
AUTH0_MGMT_CLIENT_SECRET=your_management_client_secret